# ── Ollama ────────────────────────────────────────────────────────────────────
# If running outside Docker use localhost; inside Docker use host.docker.internal
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.1:8b
CHAT_TEMPERATURE=0.1
LLM_NUM_PREDICT=1024

# ── Postgres / PGVector ───────────────────────────────────────────────────────
# SQLAlchemy DSN format required by langchain-postgres
POSTGRES_DSN=postgresql+psycopg2://postgres:password@localhost:5432/confluence_rag
DOCUMENTS_COLLECTION=documents
TOPK=8

# ── Confluence MCP Server ─────────────────────────────────────────────────────
MCP_ENDPOINT_URL=http://localhost:9240/mcp
MCP_BEARER_TOKEN=CONFLUENCE_TOKEN_HERE

# ── Quality Gate thresholds ───────────────────────────────────────────────────
MIN_SCORE=0.35
MIN_CHUNKS=2
MAX_RETRIES=2
LOW_CONFIDENCE_THRESHOLD=0.40
